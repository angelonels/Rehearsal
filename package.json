{
  "name": "rehearsal",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @rehearsal/api --filter @rehearsal/voice-agent --filter @rehearsal/web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @rehearsal/database generate",
    "db:migrate": "pnpm --filter @rehearsal/database migrate",
    "infra:up": "docker compose up -d postgres redis livekit",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}

