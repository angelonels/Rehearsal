{
  "name": "rehearsal",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --stream --filter @rehearsal/api --filter @rehearsal/voice --filter @rehearsal/web dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @rehearsal/database db:generate",
    "db:migrate": "pnpm --filter @rehearsal/database db:migrate"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
