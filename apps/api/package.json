{
  "name": "@rehearsal/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,worker -c cyan,magenta \"tsx watch src/server.ts\" \"tsx watch src/worker.ts\"",
    "worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.840.0",
    "@rehearsal/contracts": "workspace:*",
    "@rehearsal/database": "workspace:*",
    "argon2": "^0.43.0",
    "bullmq": "^5.56.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.13.3",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.2.1",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  }
}
